# Server Storage Management System 管理后台 systemd 环境变量示例
#
# 安装位置建议：
#   sudo install -m 0644 configs/storage-server.env.example /etc/ssms/storage-server.env
#   sudo vim /etc/ssms/storage-server.env

# 监听地址。使用 0.0.0.0 才能让局域网其他机器访问。
SSMS_SERVER_ADDR=0.0.0.0:8080

# SQLite 数据库路径。服务文件会使用 StateDirectory=ssms 自动创建 /var/lib/ssms。
SSMS_DB_PATH=/var/lib/ssms/server-storage.db

# Gin 运行模式。release 可以减少调试输出。
GIN_MODE=release

# Web 管理页面登录认证。生产或演示环境建议启用并填写以下字段。
SSMS_AUTH_ENABLED=0
SSMS_ADMIN_USERNAME=admin
SSMS_ADMIN_PASSWORD=
SSMS_ADMIN_PASSWORD_HASH=
SSMS_SESSION_SECRET=
