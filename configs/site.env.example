# Server Storage Management System 统一部署模板
#
# 使用方式：
#   cp configs/site.env.example configs/site.env
#   vim configs/site.env
#   scripts/apply_site_config.sh --config configs/site.env --output-dir configs
#
# 如果要直接生成到系统配置目录：
#   sudo scripts/apply_site_config.sh --config configs/site.env --output-dir /etc/ssms

# 管理后台访问地址。必须填写实际 IP 或域名。
# 示例：SSMS_MANAGEMENT_HOST="192.168.1.187"
SSMS_MANAGEMENT_HOST=""
SSMS_MANAGEMENT_PORT="8080"
SSMS_MANAGEMENT_URL=""

# 脚本调用管理后台 API 的同步配置。
BACKEND_SYNC_ENABLED="1"
BACKEND_API_TIMEOUT="5"

# 管理后台 systemd 运行参数。
SSMS_SERVER_ADDR="0.0.0.0:${SSMS_MANAGEMENT_PORT}"
SSMS_DB_PATH="/var/lib/ssms/server-storage.db"
GIN_MODE="release"

# 管理后台网页登录认证。全新部署可由 bootstrap 自动生成初始密码和会话密钥。
# 手工生成配置时，SSMS_AUTH_ENABLED=1 必须填写 SSMS_ADMIN_PASSWORD
# 或 SSMS_ADMIN_PASSWORD_HASH，并填写 SSMS_SESSION_SECRET。
SSMS_AUTH_ENABLED="1"
SSMS_ADMIN_USERNAME="admin"
SSMS_ADMIN_PASSWORD=""
SSMS_ADMIN_PASSWORD_HASH=""
SSMS_SESSION_SECRET=""

# Storage Server 与 Samba 配置。必须填写实际 IP 或域名。
# 如果管理后台和 Storage Server 同机，STORAGE_SERVER 填 SSMS_MANAGEMENT_HOST 的同一个地址。
# 示例：STORAGE_SERVER="192.168.1.187"
STORAGE_SERVER=""
STORAGE_ROOT="/srv/samba/users"
STORAGE_GROUP="storageusers"
DEFAULT_QUOTA_GB="10"
MOUNT_POINT_NAME="storage"
SMB_WORKGROUP="WORKGROUP"
SMB_NETBIOS_NAME="SSMS-STORAGE"

# 登录节点向 Storage Server 发起用户同步时使用的 SSH 配置，必须按实际部署填写。
# 示例：
#   STORAGE_SYNC_HOST="192.168.1.187"
#   STORAGE_SYNC_USER="a2"
#   STORAGE_SYNC_PROJECT_DIR="/home/a2/ServerStorageManagementSystem"
STORAGE_SYNC_HOST=""
STORAGE_SYNC_USER=""
STORAGE_SYNC_PROJECT_DIR=""
DEFAULT_SYNC_QUOTA_GB="1"

# 当前机器 Agent 配置。每台机器部署前必须分别填写 name/address。
# 主节点示例：SSMS_AGENT_NAME="MainNode"，SSMS_AGENT_ADDRESS="192.168.1.187"
# 登录节点示例：SSMS_AGENT_NAME="NodeA"，SSMS_AGENT_ADDRESS="192.168.1.188"
SSMS_AGENT_NAME=""
SSMS_AGENT_ADDRESS=""
SSMS_AGENT_DISK="/"
SSMS_AGENT_INTERVAL="30s"

# Storage Server 批量同步登录节点用户时使用的节点清单。
# 全新根服务器首次部署时可以留空，后续使用 ssmsctl node join 自动更新。
# 格式：节点名 主机地址 SSH用户 项目目录
# 示例：
# SSMS_NODES="
# NodeA 192.168.1.122 nodea1 /home/nodea1/ServerStorageManagementSystem
# NodeB 192.168.1.125 nodeb1 /home/nodeb1/ServerStorageManagementSystem
# "
SSMS_NODES="
"
